{
  "name": "crow-idl",
  "version": "0.8.0",
  "description": "A simple IDL for use with CrowCpp (C++) and TypeScript",
  "module": "build/index.js",
  "type": "module",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./IDL": {
      "types": "./build/IDL.d.ts",
      "import": "./build/IDL.js"
    }
  },
  "types": "build/src/index.d.ts",
  "bin": {
    "crow-idl": "build/src/crow-idl.js"
  },
  "scripts": {
    "format": "tools format bun",
    "clean": "rm -rf build && git restore build/NOTE.md",
    "cfg": "cd cpptests && cmake --preset debug",
    "cpp": "cd cpptests && cmake --build Debug && cd Debug/tests && ctest --output-on-failure",
    "typechk": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "bld": "tsc && bun run builder.ts",
    "build": "tsc && bun run builder.ts",
    "lint": "eslint --ext .ts src --fix",
    "justtest": "bun test",
    "testcpp": "bun run testgen && bun run format && bun run cfg && bun run cpp",
    "testgen": "bun run cpptests/generate.ts",
    "watch": "bun test --watch",
    "test": "bun run typechk && bun run testcpp && bun run justtest",
    "prepublishOnly": "bun run bld",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format",
    "pre-push": "bun run test"
  },
  "dependencies": {
    "prettier-plugin-organize-imports": "^4.3.0"
  },
  "peerDependencies": {
    "@freik/typechk": "^0.9.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@freik/typechk": "^0.9.6",
    "@freik/workspace": "^0.8.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "clang-format": "^1.8.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
